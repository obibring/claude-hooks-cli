{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../schemas/**/*.mjs",
    "../hooks/**/*.mjs",
    "../lib/handler.mjs",
    "../lib/handler-types.d.mts",
    "../lib/schema-map.mjs",
    "../index.mjs"
  ]
}
