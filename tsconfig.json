{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "schemas/**/*.mjs",
    "hooks/**/*.mjs",
    "lib/settings-io.mjs",
    "lib/hooks-store.mjs",
    "lib/hooks-manager.mjs",
    "index.mjs"
  ]
}
